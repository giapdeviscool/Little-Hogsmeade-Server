    "db:seed-pos-tables": "node ./seeds/table2.seed.js",
    "db:seed-delivery": "node ./seeds/seed_delivery_only.js",
    "db:seed-all": "node ./seeds/module4.seed.js && node ./seeds/voucher.seed.js && node ./seeds/table.seed.js && node ./seeds/table2.seed.js && node ./seeds/seed_delivery_only.js"
  },
  "prisma": {
